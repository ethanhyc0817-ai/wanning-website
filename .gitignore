# macOS system files
.DS_Store
._*
.Spotlight-V100
.Trashes

# Original (uncompressed) asset backup — keep local, don't push
Assets-original/

# Local working folders — images here get renamed/copied to parent Assets/ folders
Assets/golf/choose/

# Videos — served via Cloudinary CDN, not stored in repo
*.mp4
*.MP4
*.mov
*.MOV
*.webm

# Stray HEIC files (replaced by .jpg versions)
*.HEIC
*.heic

# Stray temp files from compression
_compressed_*

# Original (pre-compression) backups of assets we keep around locally
*.original.jpg
*.original.jpeg
*.original.png

# Internal preview / draft HTML pages — never deploy
*-preview.html
*-preview-*.html

# Editor / IDE
.vscode/
.idea/
*.swp

# Logs & env
*.log
.env
.env.*
